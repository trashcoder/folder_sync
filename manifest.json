{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "0.2.1",
  "author": "Dennis Schey",
  "default_locale": "en-US",
  "browser_specific_settings": {
    "gecko": {
      "id": "foldersync@thunderbird-addon",
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "16": "icons/sync.svg",
    "32": "icons/sync.svg",
    "48": "icons/sync.svg"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "FolderSync",
    "default_icon": {
      "16": "icons/sync.svg",
      "32": "icons/sync.svg"
    }
  },
  "options_ui": {
    "page": "options/options.html"
  },
  "background": {
    "scripts": ["folder-resolver.js", "message-matcher.js", "sync-lock.js", "sync-state-store.js", "background.js"]
  },
  "permissions": [
    "accountsRead",
    "accountsFolders",
    "messagesRead",
    "messagesMove",
    "storage",
    "alarms"
  ]
}
